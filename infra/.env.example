# ============================================================================
# sports-data-admin Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# All services (API, scraper, web) use this single .env file.
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration (Docker Postgres)
# ----------------------------------------------------------------------------
POSTGRES_DB=sports
POSTGRES_USER=sports
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
REDIS_PASSWORD=changeme_in_production

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------
# Use "development" for local development, "production" for production
ENVIRONMENT=development

# Run Alembic migrations on API startup (dev-only; default false)
RUN_MIGRATIONS=false

# ML training worker concurrency (default 2). Set to 1 on small VMs
# to avoid starving other services during experiment sweeps.
# CELERY_TRAINING_CONCURRENCY=2

# Required to run destructive restore/reset scripts
CONFIRM_DESTRUCTIVE=false

# ----------------------------------------------------------------------------
# API Authentication
# ----------------------------------------------------------------------------
# API key for authenticating requests to the API (required for production/staging)
# Generate with: openssl rand -hex 32
API_KEY=

# JWT secret for user authentication (required for production)
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-in-production

# ----------------------------------------------------------------------------
# External API Keys
# ----------------------------------------------------------------------------
# OpenAI (optional - for game flow narrative generation)
OPENAI_API_KEY=
OPENAI_MODEL_CLASSIFICATION=gpt-4o-mini
OPENAI_MODEL_SUMMARY=gpt-4o

# The Odds API (optional - for fetching betting odds)
ODDS_API_KEY=

# CBB Stats API (required for NCAAB team mapping in Alembic migrations)
CBB_STATS_API_KEY=

# DataGolf API (optional — for PGA/golf data ingestion)
# Requires Scratch PLUS subscription: https://datagolf.com/api-access
DATAGOLF_API_KEY=

# X/Twitter authentication for social scraping
# Option A: Bearer token (preferred for production)
X_BEARER_TOKEN=
# Option B: Cookie-based auth (alternative)
# Get values from browser DevTools > Application > Cookies > x.com
X_AUTH_TOKEN=
X_CT0=

# ----------------------------------------------------------------------------
# Email (optional — emails are logged when no provider is configured)
# ----------------------------------------------------------------------------
# Resend (recommended, free 100/day): https://resend.com
RESEND_API_KEY=
# SMTP fallback (if Resend is not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=noreply@scrolldownsports.com

# ----------------------------------------------------------------------------
# Frontend Configuration
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SPORTS_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# For server-side fetches inside the web container (Docker only)
SPORTS_API_INTERNAL_URL=http://api:8000

# ----------------------------------------------------------------------------
# Production Settings (required for production/staging)
# ----------------------------------------------------------------------------
# CORS origins (comma-separated)
# ALLOWED_CORS_ORIGINS=https://sda.dock108.dev
# ADMIN_ORIGINS=https://sda.dock108.dev
# FRONTEND_URL=https://sda.dock108.dev
# NEXT_PUBLIC_SPORTS_API_URL=https://sda.dock108.dev

# API_KEY must be set (min 32 characters)
# Generate with: openssl rand -hex 32

# IMPORTANT: Set ADMIN_PASSWORD as an independent secret — DO NOT reuse POSTGRES_PASSWORD.
# The docker-compose default ties these together; a single leaked password would expose
# both the database and the admin UI.
# Generate with: openssl rand -hex 32
# ADMIN_PASSWORD=

# IMPORTANT: Set GF_SECURITY_ADMIN_PASSWORD as an independent secret — DO NOT reuse POSTGRES_PASSWORD.
# Generate with: openssl rand -hex 32
# GF_SECURITY_ADMIN_PASSWORD=

# ============================================================================
# Usage:
#   Development:  docker compose --profile dev up -d
#   Production:   docker compose --profile prod up -d
#   
#   Manual backup:  docker exec sports-postgres /scripts/backup.sh
#   Restore:        CONFIRM_DESTRUCTIVE=true docker exec sports-postgres /scripts/restore.sh /backups/sports_YYYYMMDD.sql.gz
# ============================================================================
