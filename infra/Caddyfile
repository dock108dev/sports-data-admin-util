# Edge reverse-proxy site block for sports-data-admin.
#
# Merge this site block into /etc/caddy/Caddyfile on the server.
# Do not overwrite the full file if it contains other domains.
#
# Caddy sits on the host (outside Docker) and routes traffic to:
#   - FastAPI  (localhost:8000) — API + auth + realtime + docs
#   - Next.js  (localhost:3000) — Admin web UI
#
# IMPORTANT: Use `handle`, NOT `handle_path`. handle_path strips the
# matched prefix, causing FastAPI to 404 on /api/admin/... routes.

sda.dock108.dev {
	encode gzip

	# ── Security headers ─────────────────────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
		# Twitter embeds require platform.twitter.com for scripts and frames.
		# 'unsafe-inline' on style-src is required by Next.js RSC hydration.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://platform.twitter.com; frame-src https://platform.twitter.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.twitter.com; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'"
	}

	# ── FastAPI backend ──────────────────────────────────────────
	handle /api/* {
		reverse_proxy localhost:8000
	}

	handle /auth/* {
		reverse_proxy localhost:8000
	}

	handle /v1/* {
		reverse_proxy localhost:8000
	}

	handle /healthz {
		reverse_proxy localhost:8000
	}

	handle /docs {
		reverse_proxy localhost:8000
	}

	handle /openapi.json {
		reverse_proxy localhost:8000
	}

	# ── Next.js admin UI (catch-all) ────────────────────────────
	handle {
		reverse_proxy localhost:3000
	}
}
